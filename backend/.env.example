# ─────────────────────────────────────────────────────────────
# Environment Variables — copy this to .env and fill in values
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Local example:  postgresql+asyncpg://postgres:password@localhost:5432/portfolio
# Supabase example: postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/portfolio

# JWT secrets (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
REFRESH_SECRET_KEY=change-me-to-a-different-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# App environment
ENVIRONMENT=development
